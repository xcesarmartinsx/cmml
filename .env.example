# =============================================================================
# .env.example — Template de configuração do projeto CMML
# =============================================================================
# INSTRUÇÕES:
#   1) Copie este arquivo: cp .env.example .env
#   2) Preencha os valores reais em .env
#   3) NUNCA versione o .env com credenciais reais (.gitignore já o exclui)
#
# ATENÇÃO — ALINHAMENTO COM docker-compose.yml:
#   Os valores padrão abaixo correspondem ao que o docker-compose.yml cria.
#   Certifique-se de que .env e docker-compose.yml estão em sincronia.
#   Se você alterou docker-compose.yml, atualize este arquivo também.
# =============================================================================

# ──────────────────────────────────────────
# PostgreSQL (destino — container reco-postgres)
# ──────────────────────────────────────────
# Endereço do host PostgreSQL — use 127.0.0.1 para container local.
PG_HOST=127.0.0.1
# Porta do PostgreSQL — padrão 5432.
PG_PORT=5432
# Nome do banco de dados — DEVE corresponder a POSTGRES_DB no docker-compose.yml.
# Valor padrão no docker-compose: reco
PG_DB=reco
# Usuário do PostgreSQL — DEVE corresponder a POSTGRES_USER no docker-compose.yml.
# Valor padrão no docker-compose: reco
PG_USER=reco
# Senha do PostgreSQL — DEVE corresponder a POSTGRES_PASSWORD no docker-compose.yml.
# OBRIGATORIO: troque por uma senha forte antes de iniciar os containers.
PG_PASSWORD=CHANGE_ME_PG

# ──────────────────────────────────────────
# SQL Server (fonte — container sqlserver_gp)
# ──────────────────────────────────────────
# Endereço do SQL Server.
MSSQL_HOST=127.0.0.1
# Porta do SQL Server — padrão 1433.
MSSQL_PORT=1433
# Nome do banco ERP — DEVE corresponder ao banco restaurado no container.
# O backup GP_CASADASREDES161225.BAK restaura para GP_CASADASREDES
MSSQL_DB=GP_CASADASREDES
# Usuário do SQL Server — sa é o administrador do container.
MSSQL_USER=sa
# Senha do SA — DEVE corresponder a SA_PASSWORD no docker-compose.yml.
# OBRIGATORIO: troque por uma senha forte antes de iniciar os containers.
MSSQL_PASSWORD=CHANGE_ME_MSSQL
# Schema no SQL Server — normalmente dbo no ERP GP.
MSSQL_SCHEMA=dbo

# ──────────────────────────────────────────
# ETL — Identificação e performance
# ──────────────────────────────────────────
# Nome lógico do ERP — gravado em source_system em todas as tabelas de staging.
ERP_SOURCE=sqlserver_gp
# Tamanho do chunk de extração do SQL Server.
# Reduzir em caso de erros de memória; aumentar em máquinas com mais RAM.
FETCH_CHUNK=5000

# ──────────────────────────────────────────
# ETL — Logging
# ──────────────────────────────────────────
# Caminho do arquivo de log dos scripts ETL.
# Se vazio, os scripts logam apenas no console.
# O run_all.sh define ETL_LOG_FILE automaticamente com timestamp.
# Descomente para forçar um arquivo de log fixo:
# ETL_LOG_FILE=logs/etl.log

# ──────────────────────────────────────────
# pgAdmin (opcional — desenvolvimento)
# ──────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@cmml.local
# OBRIGATORIO: troque por uma senha forte antes de iniciar os containers.
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_PGADMIN

# ──────────────────────────────────────────
# Docker — Portas expostas ao host (opcional)
# ──────────────────────────────────────────
# Altere apenas se houver conflito de portas na máquina host.
# API_PORT=8001
# DASHBOARD_PORT=3000
# BUSINESS_PORT=3001
# PGADMIN_PORT=5050

# ──────────────────────────────────────────
# CORS — Origens permitidas pela API
# ──────────────────────────────────────────
# Lista de origens separadas por vírgula. Default: frontends locais.
# Em produção, substituir pelos domínios reais (ex.: https://dashboard.empresa.com).
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ──────────────────────────────────────────
# PostgreSQL — Usuários com menor privilégio
# ──────────────────────────────────────────
# Usuário da aplicação (ETL + ML pipeline) — substitui PG_USER para o pipeline
PG_APP_USER=cmml_app
PG_APP_PASSWORD=CHANGE_ME_APP
# Usuário somente leitura (API FastAPI) — usar no lugar de PG_USER para a API
PG_READONLY_USER=cmml_readonly
PG_READONLY_PASSWORD=CHANGE_ME_READONLY

# ──────────────────────────────────────────
# SQL Server — Usuário ETL com menor privilégio
# ──────────────────────────────────────────
# Usuário dedicado para o ETL (substitui MSSQL_USER=sa)
MSSQL_ETL_USER=cmml_etl
MSSQL_ETL_PASSWORD=CHANGE_ME_ETL

# ──────────────────────────────────────────
# Autenticação JWT (API)
# ──────────────────────────────────────────
# Credenciais de usuario agora ficam no banco (reco.users). Use scripts/seed_users.py para criar.
# Chave secreta para assinatura dos tokens JWT — gere com: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET
# Tempo de expiração do token em minutos (default: 480 = 8 horas)
JWT_EXPIRE_MINUTES=480

# ──────────────────────────────────────────
# ML — Parâmetros de recomendação
# ──────────────────────────────────────────
# Número de candidatos gerados por cliente antes do ranking.
RECO_CANDIDATE_SIZE=500
# Top-N final de recomendações por cliente.
RECO_TOP_N=10
# Janela de recompra em dias — produto comprado neste período não é recomendado.
RECO_RECOMPRA_WINDOW_DAYS=30

# ──────────────────────────────────────────
# Evolution API (WhatsApp validation)
# ──────────────────────────────────────────
# API key para autenticacao com Evolution API (self-hosted).
EVOLUTION_API_KEY=CHANGE_ME_EVOLUTION
# URL base da Evolution API.
EVOLUTION_API_URL=http://localhost:8080
# Nome da instancia WhatsApp configurada na Evolution API.
EVOLUTION_INSTANCE=cmml
# Dias para manter cache de validacao antes de re-verificar.
EVOLUTION_CACHE_TTL_DAYS=30
# Maximo de numeros por lote enviado a Evolution API.
EVOLUTION_BATCH_SIZE=50
# Segundos entre lotes (rate limiting para evitar ban do WhatsApp).
EVOLUTION_BATCH_DELAY=3
